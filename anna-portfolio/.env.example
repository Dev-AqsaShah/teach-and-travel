# Copy this file to .env.local for local development
# Set these in Vercel Dashboard → Project Settings → Environment Variables

# Site URL (set to your Vercel domain after deployment)
NEXT_PUBLIC_SITE_URL=https://annavolkova.com

# Calendly booking URL
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/anna-volkova

# Google Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Resend API Key — get from resend.com (for contact form emails)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email address where contact form submissions are sent
CONTACT_EMAIL_TO=anna@annavolkova.com
